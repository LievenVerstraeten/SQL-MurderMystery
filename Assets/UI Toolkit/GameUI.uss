.inventory-row {
    flex-direction: row;
    align-items: center;
    min-height: 36px;
    padding-top: 6px;
    padding-bottom: 6px;
    padding-left: 8px;
    padding-right: 8px;
    margin-bottom: 4px;
    background-color: rgb(28, 22, 18);
    border-top-color: rgba(212, 175, 55, 0.28);
    border-bottom-color: rgba(212, 175, 55, 0.08);
    border-left-color: rgba(212, 175, 55, 0.08);
    border-right-color: rgba(212, 175, 55, 0.08);
    border-width: 1px;
    border-radius: 2px;
    transition-property: background-color, border-top-color;
    transition-duration: 0.12s, 0.12s;
    transition-timing-function: ease-out, ease-out;
}

.inventory-row:hover {
    background-color: rgba(242, 202, 80, 0.09);
    border-top-color: rgba(242, 202, 80, 0.60);
}

.inventory-row--selected {
    background-color: rgba(242, 202, 80, 0.16);
    border-top-color: rgb(242, 202, 80);
    border-bottom-color: rgba(212, 175, 55, 0.38);
    border-left-color: rgba(212, 175, 55, 0.38);
    border-right-color: rgba(212, 175, 55, 0.38);
}

.inventory-icon {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgb(212, 175, 55);
    margin-right: 8px;
    flex-shrink: 0;
    -unity-text-align: middle-center;
}

.inventory-item-name {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgb(237, 224, 220);
    white-space: normal;
    flex-grow: 1;
}

.profile-card {
    flex-direction: column;
    width: 260px;
    margin: 10px;
    padding: 16px;
    background-color: rgb(38, 30, 26);
    border-top-color: rgba(242, 202, 80, 0.70);
    border-bottom-color: rgba(212, 175, 55, 0.22);
    border-left-color: rgba(212, 175, 55, 0.22);
    border-right-color: rgba(212, 175, 55, 0.22);
    border-width: 1px;
    border-radius: 3px;
    scale: 1;
    transition-property: scale, background-color, border-top-color;
    transition-duration: 0.15s, 0.15s, 0.15s;
    transition-timing-function: ease-out, ease-out, ease-out;
}

.profile-card:hover {
    background-color: rgb(52, 44, 38);
    border-top-color: rgb(255, 224, 136);
    border-bottom-color: rgba(242, 202, 80, 0.50);
    border-left-color: rgba(242, 202, 80, 0.50);
    border-right-color: rgba(242, 202, 80, 0.50);
    scale: 1.03;
}

.card-name {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 12px;
    color: rgb(242, 202, 80);
    letter-spacing: 2px;
    margin-bottom: 8px;
}

.card-date {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 8px;
    color: rgb(175, 162, 148);
    margin-bottom: 4px;
}

.card-case {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgb(212, 175, 55);
    margin-top: 6px;
}

.card-left {
    flex-grow: 1;
    flex-direction: column;
}

.card-right {
    flex-shrink: 0;
    align-items: flex-end;
    justify-content: center;
}

.card-delete {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgb(200, 80, 80);
    background-color: rgb(38, 18, 18);
    border-top-color: rgba(200, 80, 80, 0.55);
    border-bottom-color: rgba(180, 65, 65, 0.18);
    border-left-color: rgba(180, 65, 65, 0.18);
    border-right-color: rgba(180, 65, 65, 0.18);
    border-width: 1px;
    border-radius: 3px;
    padding-top: 4px;
    padding-bottom: 4px;
    padding-left: 8px;
    padding-right: 8px;
}

.card-delete:hover {
    background-color: rgb(64, 20, 20);
    border-top-color: rgb(230, 100, 100);
    color: rgb(240, 130, 130);
}

.suspect-card {
    flex-direction: column;
    padding: 12px;
    margin: 6px;
    background-color: rgb(34, 27, 23);
    border-top-color: rgba(212, 175, 55, 0.50);
    border-bottom-color: rgba(212, 175, 55, 0.15);
    border-left-color: rgba(212, 175, 55, 0.15);
    border-right-color: rgba(212, 175, 55, 0.15);
    border-width: 1px;
    border-radius: 3px;
}

.suspect-name {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 11px;
    color: rgb(237, 224, 220);
    margin-bottom: 6px;
}

.suspect-detail {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgb(175, 162, 148);
    white-space: normal;
}

.suspect-empty {
    -unity-font: url("project://database/Assets/Fonts/SpecialElite.ttf");
    font-size: 9px;
    color: rgba(175, 162, 148, 0.40);
    -unity-text-align: middle-center;
    padding: 12px;
    border-color: rgba(212, 175, 55, 0.15);
    border-width: 1px;
    border-radius: 3px;
}
